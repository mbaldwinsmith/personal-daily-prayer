{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://os-ordinariate-daily-prayer/schema/proper.schema.json",
  "title": "Proper-of-seasons / proper-of-saints override (data/proper-of-{seasons,saints}/**/*.json)",
  "description": "A partial or full override of a day's normal psalter-cycle contents for a solemnity/feast/memorial or a seasonal proper. The day-resolution function checks these before falling back to the ferial psalter/weekN - see TASKS.md Phase 8.",
  "type": "object",
  "required": ["key", "verified"],
  "additionalProperties": false,
  "properties": {
    "key": {
      "type": "string",
      "minLength": 1,
      "description": "Matches romcal's celebration key for the day, e.g. 'assumption'. See CONVENTIONS.md for cases (ferias an optional memorial might occupy) where this key isn't stable year to year."
    },
    "verified": {
      "type": "boolean",
      "description": "false = a best-effort reconstruction pending cross-check against an authoritative source (see SOURCES.md); true once confirmed."
    },
    "name": { "type": "string", "minLength": 1 },
    "firstReading": {
      "description": "Overrides the Office of Readings' scripture (first) reading - see schema/office-of-readings-day.schema.json's scriptureReading for the shape.",
      "type": "object",
      "required": ["ref"],
      "additionalProperties": false,
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "title": { "type": "string" }
      }
    },
    "hours": {
      "description": "Only the Hours actually overridden need to be present; anything omitted falls back to the ferial psalter.",
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "officeOfReadings": { "$ref": "#/$defs/hour" },
        "lauds": { "$ref": "#/$defs/hour" },
        "daytimePrayer": { "$ref": "#/$defs/hour" },
        "vespers": { "$ref": "#/$defs/hour" },
        "compline": { "$ref": "#/$defs/hour" }
      }
    },
    "secondReading": {
      "description": "Overrides the Office of Readings' patristic/hagiographic second reading only - see schema/office-of-readings-day.schema.json for the shape.",
      "type": ["object", "null"],
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "sourceRef": { "type": "string" }
      }
    }
  },
  "$defs": {
    "hour": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "psalmody": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "oneOf": [
              {
                "required": ["type", "ref"],
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "psalm" },
                  "ref": {
                    "type": "string",
                    "pattern": "^Ps [0-9]{1,3}(:[0-9]{1,3}(-[0-9]{1,3})?)?$"
                  }
                }
              },
              {
                "required": ["type", "scriptureRef"],
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "canticle" },
                  "scriptureRef": { "type": "string", "minLength": 1 },
                  "name": { "type": "string" }
                }
              },
              {
                "required": ["type", "fixedId"],
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "canticle" },
                  "fixedId": { "const": "benedicite" }
                }
              }
            ]
          }
        },
        "shortReading": { "$ref": "#/$defs/shortReading" }
      }
    },
    "shortReading": {
      "type": "object",
      "required": ["ref", "verified"],
      "additionalProperties": false,
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "verified": { "type": "boolean" }
      }
    }
  }
}
