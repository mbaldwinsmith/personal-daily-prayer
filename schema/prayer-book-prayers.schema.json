{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personal-daily-prayer/schema/prayer-book-prayers.schema.json",
  "type": "object",
  "required": ["source", "items", "assignments", "litanyDays"],
  "additionalProperties": false,
  "properties": {
    "source": { "type": "object", "required": ["title", "edition", "url"], "additionalProperties": false, "properties": { "title": { "type": "string" }, "edition": { "type": "string" }, "url": { "type": "string", "format": "uri" } } },
    "items": { "type": "object", "minProperties": 1, "additionalProperties": { "$ref": "#/$defs/item" } },
    "assignments": { "type": "object", "required": ["officeOfReadings", "lauds", "daytimePrayer", "vespers", "compline"], "additionalProperties": false, "properties": { "officeOfReadings": { "$ref": "#/$defs/ids" }, "lauds": { "$ref": "#/$defs/ids" }, "daytimePrayer": { "$ref": "#/$defs/ids" }, "vespers": { "$ref": "#/$defs/ids" }, "compline": { "$ref": "#/$defs/ids" } } },
    "litanyDays": { "type": "array", "uniqueItems": true, "items": { "enum": ["sunday", "monday", "tuesday", "wednesday", "thursday", "friday", "saturday"] } }
  },
  "$defs": {
    "ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "item": { "type": "object", "required": ["title", "kind", "verified", "sourceRef"], "additionalProperties": false, "properties": { "title": { "type": "string" }, "kind": { "enum": ["prayer", "versicles", "litany"] }, "verified": { "const": true }, "sourceRef": { "type": "string" }, "text": { "type": "string" }, "responses": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["leader", "people"], "additionalProperties": false, "properties": { "leader": { "type": "string" }, "people": { "type": "string" } } } } } }
  }
}
