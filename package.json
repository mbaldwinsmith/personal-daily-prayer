{
  "name": "personal-daily-prayer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "validate:data": "node scripts/validate-data.mjs",
    "fetch:texts": "node scripts/fetch-douay-rheims.mjs && node scripts/fetch-coverdale-psalter.mjs && node scripts/fetch-fixed-canticles.mjs && node scripts/fetch-antiphons.mjs",
    "generate:psalter-skeleton": "node scripts/generate-psalter-skeleton.mjs",
    "diff:psalter": "node scripts/diff-psalter.mjs",
    "verify:short-readings-breviarium": "node scripts/verify-short-readings-breviarium.mjs",
    "generate:advent-lent-short-readings": "node scripts/generate-advent-lent-short-readings.mjs",
    "fetch:office-of-readings": "node scripts/fetch-canonical-office-of-readings.mjs",
    "diff:office-of-readings": "node scripts/diff-office-of-readings.mjs",
    "generate:office-of-readings": "node scripts/generate-office-of-readings.mjs && node scripts/generate-office-of-readings-proper.mjs",
    "fetch:short-readings": "node scripts/fetch-canonical-short-readings.mjs",
    "diff:short-readings": "node scripts/diff-short-readings.mjs",
    "generate:short-readings-verification": "node scripts/generate-short-readings-verification.mjs"
  },
  "dependencies": {
    "romcal": "^1.3.0"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
